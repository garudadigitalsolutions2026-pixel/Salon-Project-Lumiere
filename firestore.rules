rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. Booking Validation
    function isValidBooking(data) {
      return data.keys().hasAll(['clientName', 'email', 'phone', 'serviceId', 'stylistId', 'date', 'time', 'status', 'createdAt'])
        && data.keys().size() == 9
        && data.clientName is string && data.clientName.size() >= 2
        && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.time is string && data.time.size() <= 10
        && data.status == 'pending'
        && data.createdAt == request.time;
    }

    match /bookings/{bookingId} {
      allow create: if isValidBooking(incoming());
      // Allow list for availability check (Production hardening: filter by date in code)
      allow list: if true; 
    }

    match /otps/{email} {
      // Server-side logic handles verification. Allow unauthenticated access for MVP serverless logic.
      // In production, use Firebase Admin SDK to bypass rules.
      allow read, write: if true;
    }
  }
}
